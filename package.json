{
  "name": "aret\u00e9-life-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doctor": "bash ./scripts/doctor.sh",
    "typecheck": "tsc --noEmit",
    "check": "bash scripts/quality.sh --fast",
    "check:standard": "bash scripts/quality.sh --standard",
    "check:full": "bash scripts/quality.sh --full",
    "auto": "node scripts/devops/glance-devops.js --checkpoint=5",
    "auto:fast": "node scripts/devops/glance-devops.js --checkpoint=10",
    "auto:careful": "node scripts/devops/glance-devops.js --checkpoint=3",
    "devops:auto": "node scripts/devops/glance-devops.js",
    "devops:manual": "node scripts/devops/glance-devops.js --manual",
    "devops:digest": "node scripts/devops/glance-devops.js --digest",
    "test": "echo \"No tests yet\"",
    "test:e2e": "playwright test",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "node -e \"process.env.VERCEL || require('child_process').execSync('npx playwright install --with-deps',{stdio:'inherit'})\""
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react-responsive": "^8.0.8",
    "@vercel/blob": "^0.27.0",
    "@vercel/node": "^5.6.21",
    "framer-motion": "^12.29.2",
    "groq-sdk": "^0.37.0",
    "lucide-react": "^0.562.0",
    "openai": "^6.17.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^9.0.1",
    "react-responsive": "^10.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.58.0",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
