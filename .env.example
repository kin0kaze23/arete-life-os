# === Provider API Keys ===
# Paste real keys in your local .env/.env.local only. Never commit secrets.

# Primary provider (required)
OPENAI_API_KEY=

# Fallback provider
XAI_API_KEY=
GROQ_API_KEY=

# Optional: Gemini (only needed for Voice Advisor live audio feature)
GEMINI_API_KEY=

# Other providers (optional)
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=

# === Model Router ===
# All AI actions route through the model router with automatic fallback.

# Global default lane (quality + cost balance)
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5-mini
AI_DEFAULT_TEMPERATURE=0.2

# Global fallback lane (cheap, large context)
AI_FALLBACK_PROVIDER=xai
AI_FALLBACK_MODEL=grok-4-fast-non-reasoning

# OpenAI client defaults
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low

# === Per-Action Model Assignment (optional) ===
# Format: PROVIDER:MODEL_NAME
# Uncomment to route specific actions to different models.
# When omitted, actions use AI_DEFAULT_PROVIDER:AI_DEFAULT_MODEL.
# AI_MODEL_PROCESS_INPUT=openai:gpt-5-mini
# AI_MODEL_DAILY_INTELLIGENCE_BATCH=openai:gpt-5-mini
# AI_MODEL_GENERATE_TASKS=openai:gpt-5-mini
# AI_MODEL_GENERATE_INSIGHTS=openai:gpt-5-mini
# AI_MODEL_GENERATE_BLIND_SPOTS=openai:gpt-5-mini
# AI_MODEL_GENERATE_DEEP_TASKS=openai:gpt-5-mini
# AI_MODEL_GENERATE_DAILY_PLAN=openai:gpt-5-mini
# AI_MODEL_ASK_AURA=openai:gpt-5-mini
# AI_MODEL_GENERATE_EVENT_PREP_PLAN=openai:gpt-5-mini
# AI_MODEL_GENERATE_DEEP_INITIALIZATION=openai:gpt-5-mini
# AI_MODEL_GENERATE_BASELINE_SWOT=openai:gpt-5-mini
# AI_MODEL_REFRESH_DIMENSION_CONTEXTS=openai:gpt-5-mini
# AI_MODEL_GENERATE_LIFE_SNAPSHOT=openai:gpt-5-mini
