# === Clerk Authentication (Required) ===
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === AI Providers ===
# Gemini API key (server-only; do not commit real values)
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-3-pro-preview
GEMINI_MODEL_FLASH=gemini-3-flash-preview
GEMINI_MODEL_FLASH_LITE=gemini-2.5-flash-lite

# === Optional Model Router ===
AI_USE_ROUTER=0
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-2.5-flash
AI_DEFAULT_TEMPERATURE=0.7
AI_FALLBACK_PROVIDER=openai
AI_FALLBACK_MODEL=gpt-5.1

# === Per-Action Model Assignment (when AI_USE_ROUTER=1) ===
# Format: PROVIDER:MODEL_NAME
AI_MODEL_PROCESS_INPUT=gemini:gemini-2.5-flash-lite
AI_MODEL_DAILY_INTELLIGENCE_BATCH=gemini:gemini-2.5-pro
AI_MODEL_GENERATE_TASKS=gemini:gemini-2.5-flash
AI_MODEL_GENERATE_INSIGHTS=gemini:gemini-2.5-pro
AI_MODEL_GENERATE_BLIND_SPOTS=gemini:gemini-2.5-pro
AI_MODEL_GENERATE_DEEP_TASKS=gemini:gemini-2.5-pro
AI_MODEL_GENERATE_DAILY_PLAN=gemini:gemini-2.5-flash
AI_MODEL_ASK_AURA=gemini:gemini-2.5-pro
AI_MODEL_GENERATE_EVENT_PREP_PLAN=gemini:gemini-2.5-flash
AI_MODEL_GENERATE_DEEP_INITIALIZATION=gemini:gemini-2.5-pro

# OpenAI fallback (server-only; optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_REASONING_EFFORT=medium

# Other providers (server-only; optional)
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
